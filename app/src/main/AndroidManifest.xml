<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Read-only Health Connect permissions. No WRITE_* permission is declared anywhere
         in this manifest — PR2's hard boundary is read-only, enforced at the manifest level
         as well as in code. -->
    <uses-permission android:name="android.permission.health.READ_STEPS" />
    <uses-permission android:name="android.permission.health.READ_SLEEP" />
    <uses-permission android:name="android.permission.health.READ_HEART_RATE" />
    <uses-permission android:name="android.permission.health.READ_NUTRITION" />
    <uses-permission android:name="android.permission.health.READ_WEIGHT" />
    <uses-permission android:name="android.permission.health.READ_BODY_FAT" />

    <!-- Additional read permissions for the Samsung Health Capability Sweep (WP2). Read-only,
         Samsung-filtered at read time. Still no WRITE_* permission anywhere. -->
    <uses-permission android:name="android.permission.health.READ_DISTANCE" />
    <uses-permission android:name="android.permission.health.READ_FLOORS_CLIMBED" />
    <uses-permission android:name="android.permission.health.READ_ACTIVE_CALORIES_BURNED" />
    <uses-permission android:name="android.permission.health.READ_TOTAL_CALORIES_BURNED" />
    <uses-permission android:name="android.permission.health.READ_EXERCISE" />
    <uses-permission android:name="android.permission.health.READ_ELEVATION_GAINED" />
    <uses-permission android:name="android.permission.health.READ_SPEED" />
    <uses-permission android:name="android.permission.health.READ_POWER" />
    <uses-permission android:name="android.permission.health.READ_RESTING_HEART_RATE" />
    <uses-permission android:name="android.permission.health.READ_HEART_RATE_VARIABILITY" />
    <uses-permission android:name="android.permission.health.READ_OXYGEN_SATURATION" />
    <uses-permission android:name="android.permission.health.READ_RESPIRATORY_RATE" />
    <uses-permission android:name="android.permission.health.READ_BLOOD_PRESSURE" />
    <uses-permission android:name="android.permission.health.READ_BLOOD_GLUCOSE" />
    <uses-permission android:name="android.permission.health.READ_BODY_TEMPERATURE" />

    <!-- Package-visibility declaration required to query the Health Connect provider app. -->
    <queries>
        <package android:name="com.google.android.apps.healthdata" />
    </queries>

    <application
        android:label="@string/app_name"
        android:theme="@style/Theme.FusionHealth"
        android:allowBackup="false">

        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- WP2/PR4b diagnostic spike: incremental-sync capability investigation. A separate,
             independently-launched activity (own app-drawer icon) so WP1/PR2's device-proven
             MainActivity flow is left untouched. Read-only, no persistence. -->
        <!-- Distinct taskAffinity + singleTask so tapping this launcher icon always surfaces THIS
             activity in its own task, rather than resuming whichever Fusion activity was last on
             top (multiple launcher entries in one app otherwise collide on the default task). -->
        <activity
            android:name=".SyncSpikeActivity"
            android:exported="true"
            android:launchMode="singleTask"
            android:taskAffinity="com.fusionhealth.diagnostic.syncspike">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- WP2 Samsung Health Capability Sweep: read-only inventory of Samsung-originated data
             available through Health Connect. Separate, independently-launched activity (distinct
             app-drawer name) so MainActivity and SyncSpikeActivity are left untouched. -->
        <activity
            android:name=".SamsungSweepActivity"
            android:label="Samsung Capability Sweep"
            android:exported="true"
            android:launchMode="singleTask"
            android:taskAffinity="com.fusionhealth.diagnostic.samsungsweep">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Dedicated permissions-rationale / privacy activity. Health Connect requires an app
             to declare a rationale surface to be discoverable in its permissions UI; PR2's
             original build only had the pre-Android-14 intent-filter on MainActivity, which
             left the app invisible to Health Connect on the Android 14+ device Warwick tested
             on (no permission screen shown, app absent from Health Connect's app list, all
             reads PERMISSION_DENIED). This activity plus the alias below fixes that. -->
        <activity
            android:name=".PermissionsRationaleActivity"
            android:exported="true">
            <!-- Pre-Android-14 mechanism (retained). -->
            <intent-filter>
                <action android:name="androidx.health.ACTION_SHOW_PERMISSIONS_RATIONALE" />
            </intent-filter>
        </activity>

        <!-- Android 14+ mechanism: Health Connect resolves this exact alias/intent-filter
             combination to find the rationale activity. -->
        <activity-alias
            android:name=".PermissionsRationaleActivityAlias"
            android:exported="true"
            android:targetActivity=".PermissionsRationaleActivity"
            android:permission="android.permission.START_VIEW_PERMISSION_USAGE">
            <intent-filter>
                <action android:name="android.intent.action.VIEW_PERMISSION_USAGE" />
                <category android:name="android.intent.category.HEALTH_PERMISSIONS" />
            </intent-filter>
        </activity-alias>
    </application>

</manifest>
